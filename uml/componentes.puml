@startuml Diagrama de Componentes - Arquitectura SRAP

skinparam componentStyle uml2

package "Cliente (PC de Registro)" {
    [Navegador Web] as Browser
    component "Frontend\nNext.js" as Frontend {
        [Páginas] as Pages
        [Componentes] as Components
        [Estado\nLocalStorage] as State
    }
}

package "Hardware" {
    [Lector NFC USB] as LectorUSB
    [Tarjeta NFC] as NFCCard
}

package "Servidor" {
    component "Backend\nNestJS" as Backend {
        [AuthModule] as Auth
        [EmpleadosModule] as Empleados
        [AsistenciasModule] as Asistencias
        [NfcModule] as NfcMod
        [HorariosModule] as Horarios
        [VacacionesModule] as Vacaciones
        [PermisosModule] as Permisos
        [DiasFestivosModule] as Festivos
        [BitacoraModule] as Bitacora
        [ReportesModule] as Reportes
    }
    
    [API REST\n/api/*] as API
    [JWT Auth\nMiddleware] as JWTMiddleware
}

database "PostgreSQL" as DB {
    [empleados]
    [usuarios]
    [asistencias]
    [horarios]
    [tarjetas_nfc]
    [vacaciones]
    [permisos]
    [dias_festivos]
    [bitacora]
}

' Conexiones Frontend e Ingreso de Datos
NFCCard --> LectorUSB : RFID
LectorUSB --> Browser : Entrada de Teclado USB (Emulación HID)
Browser --> Frontend : Eventos KeyDown / onChange (Captura de UID)
Browser --> Frontend : HTTP/HTTPS
Frontend --> API : REST + JWT (Petición POST a /api/nfc/lectura)

' Conexiones API
API --> JWTMiddleware : Validar Token
JWTMiddleware --> Auth
JWTMiddleware --> Empleados
JWTMiddleware --> Asistencias
JWTMiddleware --> Horarios
JWTMiddleware --> Vacaciones
JWTMiddleware --> Permisos
JWTMiddleware --> Festivos
JWTMiddleware --> Bitacora
JWTMiddleware --> Reportes

' Conexiones de Negocio
NfcMod --> Asistencias : Registrar Asistencia

' Conexiones DB
Auth --> DB
Empleados --> DB
Asistencias --> DB
NfcMod --> DB
Horarios --> DB
Vacaciones --> DB
Permisos --> DB
Festivos --> DB
Bitacora --> DB
Reportes --> DB

note right of Frontend
  - React 19 / Next.js
  - TypeScript
  - CSS Modules
  - Zustand (estado)
end note

note right of Backend
  - TypeScript
  - TypeORM
  - class-validator
  - bcrypt
end note

note right of LectorUSB
  - Emulación de teclado HID
  - Conexión Plug & Play por USB
  - Escribe el UID de la tarjeta en el campo enfocado
  - Envía retorno de carro (Enter) al finalizar
end note

@enduml
